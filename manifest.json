{
  "manifest_version": 3,
  "name": "AutoFill Pro - CV Auto Form Filler",
  "version": "1.9.0",
  "description": "Smart Chrome extension that auto-fills job application forms from client resumes (AI-powered)",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*", "background/ai.js", "logo.png", "utils/crypto.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://indeed.com/*",
    "https://*.indeed.com/*",
    "https://stepstone.de/*",
    "https://*.stepstone.de/*",
    "https://xing.com/*",
    "https://*.xing.com/*",
    "https://glassdoor.com/*",
    "https://*.glassdoor.com/*",
    "https://monster.de/*",
    "https://*.monster.de/*",
    "https://arbeitsagentur.de/*",
    "https://*.arbeitsagentur.de/*"
  ]
}